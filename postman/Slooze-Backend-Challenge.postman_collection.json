              "raw": "{\n  \"query\": \"mutation SaveCart($input: SaveCartInput!) { saveCart(input: $input) { id status total restaurantId paymentMethodId items { menuItemId quantity unitPrice menuItem { name } } } }\",\n  \"variables\": {\n    \"input\": {\n      \"restaurantId\": \"{{restaurantId}}\",\n      \"paymentMethodId\": \"{{paymentMethodId}}\",\n      \"items\": [\n        { \"menuItemId\": \"{{menuItemId}}\", \"quantity\": 2 }\n      ]\n    }\n  }\n}"
